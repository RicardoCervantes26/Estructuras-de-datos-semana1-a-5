import java.util.Arrays; // Solo lo usamos para imprimir el resultado final de forma bonita

public class OperacionesBasicas {
    public static void main(String[] args) {

        // 1. Definición de arreglos iniciales
        int[] arreglo1 = {1, 2, 3};
        int[] arreglo2 = {4, 5, 6};
        int[] arregloIgualA1 = {1, 2, 3};

        // --- OPERACIÓN: COMPARACIÓN ---
        boolean sonIguales = true;
        
        // Primero verificamos si tienen el mismo tamaño
        if (arreglo1.length != arregloIgualA1.length) {
            sonIguales = false;
        } else {
            // Comparamos elemento por elemento
            for (int i = 0; i < arreglo1.length; i++) {
                if (arreglo1[i] != arregloIgualA1[i]) {
                    sonIguales = false;
                    break; // Si uno falla, ya no necesitamos seguir revisando
                }
            }
        }
        System.out.println("¿Arreglo 1 es igual al de prueba?: " + sonIguales);

        // --- OPERACIÓN: CLONACIÓN ---
        int[] copiaArreglo1 = new int[arreglo1.length];
        
        for (int i = 0; i < arreglo1.length; i++) {
            copiaArreglo1[i] = arreglo1[i];
        }
        System.out.println("Copia del Arreglo 1: " + Arrays.toString(copiaArreglo1));

        // --- OPERACIÓN: FUSIÓN (CONCATENACIÓN) ---
        int[] fusionado = new int[arreglo1.length + arreglo2.length];

        // Primer for: Meter los elementos del primer arreglo
        for (int i = 0; i < arreglo1.length; i++) {
            fusionado[i] = arreglo1[i];
        }

        // Segundo for: Meter los del segundo arreglo empezando donde terminó el anterior
        for (int i = 0; i < arreglo2.length; i++) {
            fusionado[arreglo1.length + i] = arreglo2[i];
        }

        System.out.println("Arreglo Final (Fusión): " + Arrays.toString(fusionado));
    }
}

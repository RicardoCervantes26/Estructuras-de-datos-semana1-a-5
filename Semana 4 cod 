    public static void ejecutarTriangularInferior(int n) {
        System.out.println("=== MATRIZ TRIANGULAR INFERIOR ===");
        int[][] matriz = new int[n][n];
        for (int i = 0; i < n; i++) {
            for (int j = 0; j <= i; j++) {
                matriz[i][j] = i + j; 
            }
        }
        imprimir(matriz);
    }

    public static void ejecutarTriangularSuperior(int n) {
        System.out.println("=== MATRIZ TRIANGULAR SUPERIOR ===");
        int[][] matriz = new int[n][n];
        for (int i = 0; i < n; i++) {
            for (int j = i; j < n; j++) {
                matriz[i][j] = i + j;
            }
        }
        imprimir(matriz);
    }

    public static void ejecutarTridiagonal(int n) {
        System.out.println("=== MATRIZ TRIDIAGONAL ===");
        int[][] matriz = new int[n][n];
        for (int i = 0; i < n; i++) {
            matriz[i][i] = i + 1; [span_7](start_span)// Principal[span_7](end_span)
            if (i < n - 1) {
                matriz[i][i + 1] = i + 2; [span_8](start_span)// Superior[span_8](end_span)
                matriz[i + 1][i] = i + 3; [span_9](start_span)// Inferior[span_9](end_span)
            }
        }
        imprimir(matriz);
    }

    public static void ejecutarSimetrica(int n) {
        System.out.println("=== MATRIZ SIMÉTRICA ===");
        int[][] matriz = new int[n][n];
        for (int i = 0; i < n; i++) {
